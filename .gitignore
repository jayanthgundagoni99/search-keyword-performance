# AWS CDK - Handled by infra/.gitignore mostly, but good to have for context
cdk.out/
cdk.context.json
cdk.outputs.json # Standard CDK output with dot
cdk-outputs.json # For hyphenated version like client-deployments/sandbox-test/cdk-outputs.json
/cdk.out # also ignore if at root, though typically in .gitignore of infra dir itself if cdk init was run there

# Node.js / npm / yarn - General, primarily for any root-level node activities
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# package-lock.json # If you use yarn.lock at root, or vice-versa
# yarn.lock # If you use package-lock.json at root

# Python
__pycache__/
*.py[cod]
*.so # C extensions
.Python
build/
dist/
develop-eggs/
*.egg-info/
*.egg
*.manifest
*.spec

# Virtual environments
env/
venv/
.venv/
ENV/

# Test & Coverage artifacts
.pytest_cache/
.mypy_cache/
.tox/
htmlcov/
.coverage
.coverage.*

# IDE / Editor specific
.vscode/
.idea/

# OS specific
.DS_Store
._*
Thumbs.db

# Temporary files
*.tmp
*.swp
*.swo

# Secrets / Credentials - IMPORTANT!
# Add any files containing sensitive information that should NOT be in git
# e.g.:
# .env
# local_settings.py
# my_credentials.json

# Compiled files from other languages if any (e.g. Java .class)
*.class

# Generated output files (search keyword performance)
*_SearchKeywordPerformance.tab
!output/*_SearchKeywordPerformance.tab

# Checkpoints
skp_checkpoint.json
skp_checkpoint.json.tmp

# Log files
*.log
logs/

# Runtime files
*.pid
*.seed
*.pid.lock

# Shell history
.bash_history
.zsh_history 